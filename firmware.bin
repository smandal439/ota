#include <Arduino.h>
#include "A7670E.h"
#include <Update.h>

A7670E modem(Serial1, 9600);  // Define A7670E serial interface

const char* firmwareURL = "https://github.com/smandal439/ota/releases/download/v1.0/firmware.bin";  // Replace with your GitHub direct link

void setup() {
    Serial.begin(115200);
    modem.begin();  // Initialize A7670E

    Serial.println("Starting OTA update via GSM...");
    otaUpdate(firmwareURL);
}

void otaUpdate(const char* url) {
    modem.httpInit();  // Initialize HTTP connection
    
    if (modem.httpGet(url)) {
        int fileSize = modem.httpGetSize();  // Get file size
        if (fileSize <= 0) {
            Serial.println("Invalid firmware file size!");
            return;
        }

        if (Update.begin(fileSize)) {
            Serial.println("Downloading firmware...");
            uint8_t buffer[512];
            int bytesRead;
            
            while ((bytesRead = modem.httpRead(buffer, sizeof(buffer))) > 0) {
                Update.write(buffer, bytesRead);  // Write to ESP32 flash
            }

            if (Update.end(true)) {
                Serial.println("OTA update successful! Rebooting...");
                ESP.restart();
            } else {
                Serial.println("Update failed!");
            }
        } else {
            Serial.println("Not enough space for OTA update.");
        }
    } else {
        Serial.println("HTTP request failed!");
    }

    modem.httpEnd();
}

void loop() {
    // Empty loop
}
